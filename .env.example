PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskBoard?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────
# Redis — pick ONE option:
# ─────────────────────────────────────────────────────────────────

# Option A: Cloud Redis (Upstash — free at https://upstash.com)
#   1. Sign up at https://upstash.com
#   2. Create a Redis database (select region closest to you)
#   3. Go to database dashboard → copy "UPSTASH_REDIS_URL"  (starts with rediss://)
#   4. Paste it below and comment out the Option B variables
REDIS_URL=rediss://default:<password>@<host>.upstash.io:<port>

# Option B: Local Redis (Docker)
#   Run from taskBoard/redis folder: docker-compose up -d
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=12345
# ─────────────────────────────────────────────────────────────────

# Session
SESSION_SECRET=your-super-secret-session-key-change-this
SESSION_EXPIRY=3600

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=60

# Login Attempt Tracking
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_DURATION=900

# Task Cache TTL in seconds
TASK_CACHE_TTL=300
